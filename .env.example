# Copy to .env and set for production.
# For local dev you can leave these unset (defaults: http://localhost:8000, port 8000).

# Public URL of this app (no trailing slash). Required for verification links and did:web.
BASE_URL=https://your-app-name.onrender.com

# Port (Render/Fly set this automatically; only set for local Docker).
# PORT=8000
